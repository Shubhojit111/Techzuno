# Server Environment Variables
PORT=5000
MONGO_URI=mongodb://localhost:27017/techzuno
JWT_SECRET=your_jwt_secret_here

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_admin_password_here

DB_HOST=localhost
DB_USER=root
DB_PASS=
